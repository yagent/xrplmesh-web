---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Distributed XRPL proxy network with edge caching. Free, fast, open API for the XRP Ledger.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={`https://xrplmesh.com${Astro.url.pathname}`} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://xrplmesh.com${Astro.url.pathname}`} />
  <meta property="og:site_name" content="XRPL Mesh" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
