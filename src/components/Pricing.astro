---
import { Check } from 'lucide-astro';

interface Props { userPlan?: string; }
const { userPlan = '' } = Astro.props;

const planTier: Record<string, number> = { free: 0, builder: 1, pro: 2, scale: 3, enterprise: 4 };
const currentTier = planTier[userPlan] ?? -1;

const plans = [
  { name: 'Free', price: '$0', period: '/forever', plan: 'free', limit: '15 req/s', credits: '10M', features: ['Full ledger history', 'WebSocket & HTTP', 'API key required', 'Community support'], cta: 'Get Free Key', highlight: false },
  { name: 'Builder', price: '$29', period: '/month', plan: 'builder', limit: '50 req/s', credits: '100M', features: ['Full ledger history', 'WebSocket & HTTP', 'Priority routing', 'Usage dashboard'], cta: 'Subscribe', highlight: false },
  { name: 'Pro', price: '$79', period: '/month', plan: 'pro', limit: '150 req/s', credits: '500M', features: ['Full ledger history', 'WebSocket & HTTP', 'Priority routing', 'Usage dashboard', 'Dedicated support'], cta: 'Subscribe', highlight: true },
  { name: 'Scale', price: '$199', period: '/month', plan: 'scale', limit: '300 req/s', credits: '2B', features: ['Full ledger history', 'WebSocket & HTTP', 'Priority routing', 'Usage dashboard', 'Dedicated support', 'Custom SLA'], cta: 'Subscribe', highlight: false },
];

function getCta(plan: string) {
  const tier = planTier[plan] ?? 0;
  if (currentTier >= 4) return 'Enterprise';
  if (plan === userPlan) return 'Current Plan';
  if (tier < currentTier) return 'Current: ' + userPlan.charAt(0).toUpperCase() + userPlan.slice(1);
  if (plan === 'free') return userPlan ? 'Current: ' + userPlan.charAt(0).toUpperCase() + userPlan.slice(1) : 'Get Free Key';
  return 'Subscribe';
}

function isDisabled(plan: string) {
  const tier = planTier[plan] ?? 0;
  return currentTier >= 4 || plan === userPlan || tier <= currentTier;
}
---

<section class="pricing-section" id="pricing">
  <h2>Pricing</h2>
  <p class="pricing-sub">Simple, transparent pricing. Full history on every plan. No credit system.</p>

  <div class="pricing-grid">
    {plans.map(p => (
      <div class={`plan ${p.highlight && p.plan !== userPlan ? 'plan-highlight' : ''} ${p.plan === userPlan ? 'plan-current' : ''}`}>
        {p.plan === userPlan && <div class="plan-badge current-badge">Your Plan</div>}
        {p.highlight && p.plan !== userPlan && <div class="plan-badge">Most Popular</div>}
        <div class="plan-header">
          <div class="plan-name">{p.name}</div>
          <div class="plan-price">
            <span class="price">{p.price}</span>
            <span class="period">{p.period}</span>
          </div>
        </div>
        <div class="plan-metrics">
          <div class="metric">
            <span class="metric-value">{p.limit}</span>
            <span class="metric-label">Rate limit</span>
          </div>
          <div class="metric">
            <span class="metric-value">{p.credits}</span>
            <span class="metric-label">Credits/mo</span>
          </div>
        </div>
        <div class="plan-divider"></div>
        <ul class="plan-features">
          {p.features.map(f => (
            <li><Check size={14} /><span>{f}</span></li>
          ))}
        </ul>
        <button
          class={`plan-cta ${p.plan === userPlan ? 'plan-cta-current' : ''}`}
          data-plan={p.plan}
          disabled={isDisabled(p.plan)}
          onclick={isDisabled(p.plan) ? undefined : p.plan === 'free'
            ? "window.location.hash='quickstart'"
            : `handleCheckout('${p.plan}')`
          }
        >
          {getCta(p.plan)}
        </button>
      </div>
    ))}
  </div>

  <p class="pricing-note">All plans include full XRPL ledger history since genesis. 40 credits per request. No archive add-ons.</p>
</section>

<script is:inline>
  async function handleCheckout(plan) {
    try {
      const resp = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ plan }),
      });
      const data = await resp.json();
      if (data.url) {
        window.location.href = data.url;
      } else {
        alert('Error: ' + (data.error || 'Unknown error'));
      }
    } catch (e) {
      alert('Failed to create checkout session');
    }
  }
</script>

<style>
  .pricing-section { margin-bottom: 56px; }
  .pricing-section h2 { font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 8px; }
  .pricing-sub { text-align: center; color: var(--text-muted); font-size: 0.95rem; margin-bottom: 32px; }
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
  }
  .plan {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: border-color 0.2s, transform 0.2s;
  }
  .plan:hover { border-color: rgba(88,166,255,0.3); transform: translateY(-2px); }
  .plan-highlight {
    border-color: var(--accent);
    box-shadow: 0 0 30px rgba(88,166,255,0.08);
  }
  .plan-badge {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: #0a0e17;
    font-size: 0.65rem;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .plan-header { margin-bottom: 20px; }
  .plan-name { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.06em; }
  .plan-price { display: flex; align-items: baseline; gap: 2px; }
  .price { font-size: 2.2rem; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
  .period { font-size: 0.8rem; color: var(--text-dim); }
  .plan-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .metric { background: rgba(88,166,255,0.04); border: 1px solid rgba(88,166,255,0.08); border-radius: 8px; padding: 10px; text-align: center; }
  .metric-value { display: block; font-size: 0.95rem; font-weight: 700; color: var(--accent); font-family: var(--mono); }
  .metric-label { display: block; font-size: 0.65rem; color: var(--text-dim); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }
  .plan-divider { height: 1px; background: var(--border); margin-bottom: 16px; }
  .plan-features {
    list-style: none;
    padding: 0;
    flex: 1;
    margin-bottom: 20px;
  }
  .plan-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 0;
    font-size: 0.83rem;
    color: var(--text-muted);
  }
  .plan-features li :global(svg) { color: var(--accent); flex-shrink: 0; }
  .plan-cta {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: var(--font);
  }
  .plan-cta:hover { border-color: var(--accent); color: var(--accent); }
  .plan-highlight .plan-cta {
    background: var(--accent);
    color: #0a0e17;
    border-color: var(--accent);
  }
  .plan-highlight .plan-cta:hover { background: #79c0ff; }
  .plan-current { border-color: #3fb950; box-shadow: 0 0 30px rgba(63,185,80,0.08); }
  .current-badge { background: #3fb950 !important; }
  .plan-cta-current { border-color: #3fb950; color: #3fb950; cursor: default; }
  .plan-cta:disabled { opacity: 0.4; cursor: not-allowed; }
  .plan-cta:disabled:hover { border-color: var(--border); color: var(--text); }
  .pricing-note { text-align: center; color: var(--text-dim); font-size: 0.78rem; margin-top: 20px; }
</style>
