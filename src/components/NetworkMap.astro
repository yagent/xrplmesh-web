---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  network: {
    regions: Record<string, { nodes: number; online: number }>;
    nodes_online: number;
    nodes_total: number;
  };
}

const { network } = Astro.props;

let mapPaths = '';
try {
  const svg = fs.readFileSync(path.join(process.cwd(), 'public', 'world-map.svg'), 'utf8');
  const match = svg.match(/<g[^>]*>([\s\S]*)<\/g>/);
  if (match) mapPaths = match[1];
} catch {}

const regionCoords: Record<string, { x: number; y: number; label: string; country: string; latency: string; cached: string; flag: string }> = {
  'US West':      { x: 157, y: 406, label: 'US West',      country: 'US', latency: '<10ms', cached: '98%', flag: 'US' },
  'US Southwest': { x: 142, y: 430, label: 'US Southwest', country: 'US', latency: '<10ms', cached: '98%', flag: 'US' },
  'US Central':   { x: 195, y: 412, label: 'US Central',   country: 'US', latency: '<10ms', cached: '98%', flag: 'US' },
  'US Northeast': { x: 244, y: 406, label: 'US Northeast', country: 'US', latency: '<10ms', cached: '98%', flag: 'US' },
  'US Southeast': { x: 230, y: 459, label: 'US Southeast', country: 'US', latency: '<10ms', cached: '98%', flag: 'US' },
  'EU West':      { x: 413, y: 394, label: 'EU West',      country: 'EU', latency: '<5ms',  cached: '98%', flag: 'FR' },
  'EU Central':   { x: 422, y: 384, label: 'EU Central',   country: 'EU', latency: '<5ms',  cached: '98%', flag: 'DE' },
  'EU South':     { x: 423, y: 409, label: 'EU South',     country: 'EU', latency: '<5ms',  cached: '98%', flag: 'IT' },
  'EU North':     { x: 453, y: 340, label: 'EU North',     country: 'EU', latency: '<5ms',  cached: '98%', flag: 'FI' },
};

const regions = Object.entries(network.regions || {}).map(([name, r]) => ({
  name, ...r,
  coords: regionCoords[name] || { x: 400, y: 200, label: name },
}));

// Build mesh connections (all pairs)
const connections: { x1: number; y1: number; x2: number; y2: number }[] = [];
for (let i = 0; i < regions.length; i++) {
  for (let j = i + 1; j < regions.length; j++) {
    connections.push({
      x1: regions[i].coords.x, y1: regions[i].coords.y,
      x2: regions[j].coords.x, y2: regions[j].coords.y,
    });
  }
}

// Query simulation: alternate between US and EU entry points
const usIdx = regions.map((r, i) => r.coords.label?.startsWith('US') ? i : -1).filter(i => i >= 0);
const euIdx = regions.map((r, i) => r.coords.label?.startsWith('EU') ? i : -1).filter(i => i >= 0);
const queryOrder = [];
const maxLen = Math.max(usIdx.length, euIdx.length);
for (let i = 0; i < maxLen; i++) {
  if (usIdx[i] !== undefined) queryOrder.push(usIdx[i]);
  if (euIdx[i] !== undefined) queryOrder.push(euIdx[i]);
}

const totalDur = queryOrder.length * 4; // full cycle duration
const queryPaths = queryOrder.map((entry, qi) => {
  // Fan out to 2-3 nearby nodes
  const nearby = regions.map((_, i) => i).filter(i => i !== entry).sort((a, b) => {
    const da = Math.hypot(regions[a].coords.x - regions[entry].coords.x, regions[a].coords.y - regions[entry].coords.y);
    const db = Math.hypot(regions[b].coords.x - regions[entry].coords.x, regions[b].coords.y - regions[entry].coords.y);
    return da - db;
  }).slice(0, 3);
  return { entry, targets: nearby, delay: qi * 4 };
});
---

<section class="map-section">

  <div class="map-container">
    <svg class="map-svg" viewBox="30.767 241.591 784.077 458.627" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <radialGradient id="node-glow">
          <stop offset="0%" stop-color="rgba(88,166,255,0.3)" />
          <stop offset="100%" stop-color="transparent" />
        </radialGradient>
        <radialGradient id="query-glow">
          <stop offset="0%" stop-color="rgba(46,204,113,0.4)" />
          <stop offset="100%" stop-color="transparent" />
        </radialGradient>
        <filter id="glow">
          <feGaussianBlur stdDeviation="2" result="blur" />
          <feMerge><feMergeNode in="blur" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
      </defs>

      <!-- World map -->
      <g class="world-paths" set:html={mapPaths} />

      <!-- Mesh connections hidden for clean look -->

      <!-- Query simulation: user request arrives, propagates through mesh -->
      {queryPaths.map((q, qi) => {
        const entry = regions[q.entry]?.coords;
        if (!entry) return null;
        // User dot approaches from outside
        // Users query from real countries around the world
        const origins = [
          [287, 618],  // Brazil
          [709, 426],  // Japan
          [673, 609],  // Australia
          [134, 434],  // Mexico
          [520, 458],  // Saudi Arabia
          [594, 386],  // China
          [475, 596],  // South Africa
          [696, 410],  // South Korea
          [554, 455],  // Pakistan
        ];
        const [userX, userY] = origins[qi % origins.length];
        return (
          <g class="query-group">
            {/* User request incoming — vary direction per query */}
            <path id={`qpath-in-${qi}`} d={`M${userX},${userY} L${entry.x},${entry.y}`} fill="none" stroke="none" />
            {/* Request trail line */}
            <line x1={userX} y1={userY} x2={entry.x} y2={entry.y} class="request-trail">
              <animate attributeName="opacity" values="0;0.3;0" dur="1.5s" repeatCount="indefinite" begin={`${q.delay}s`} />
            </line>
            <circle r="2.5" class="query-packet">
              <animateMotion dur="1.5s" repeatCount="indefinite" begin={`${q.delay}s`} fill="freeze">
                <mpath href={`#qpath-in-${qi}`} />
              </animateMotion>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.8;1" dur="1.5s" repeatCount="indefinite" begin={`${q.delay}s`} />
            </circle>

            {/* Entry node flash on receive */}
            <circle cx={entry.x} cy={entry.y} r="3" class="node-flash">
              <animate attributeName="r" values="3;12;3" dur="1.5s" repeatCount="indefinite" begin={`${q.delay + 0.7}s`} />
              <animate attributeName="opacity" values="0;0.6;0" dur="1.5s" repeatCount="indefinite" begin={`${q.delay + 0.7}s`} />
            </circle>

            {/* Propagation to peer nodes */}
            {q.targets.map((t, ti) => {
              const target = regions[t]?.coords;
              if (!target) return null;
              const pathId = `qpath-${qi}-${ti}`;
              return (
                <g>
                  <path id={pathId} d={`M${entry.x},${entry.y} L${target.x},${target.y}`} fill="none" stroke="none" />
                  {/* Node flash on propagation */}
                  <circle cx={target.x} cy={target.y} r="3" class="node-flash">
                    <animate attributeName="r" values="3;10;3" dur="1s" repeatCount="indefinite" begin={`${q.delay + 1.2 + ti * 0.2}s`} />
                    <animate attributeName="opacity" values="0;0.4;0" dur="1s" repeatCount="indefinite" begin={`${q.delay + 1.2 + ti * 0.2}s`} />
                  </circle>
                </g>
              );
            })}

            {/* Response back to user */}
            <circle r="2.5" class="resp-packet-user">
              <animateMotion dur="1s" repeatCount="indefinite" begin={`${q.delay + 3}s`} keyPoints="1;0" keyTimes="0;1" fill="freeze">
                <mpath href={`#qpath-in-${qi}`} />
              </animateMotion>
              <animate attributeName="opacity" values="0;1;1;0" keyTimes="0;0.1;0.8;1" dur="1s" repeatCount="indefinite" begin={`${q.delay + 3}s`} />
            </circle>
          </g>
        );
      })}

      <!-- Node markers -->
      {regions.map((r, i) => (
        <g>
          <circle cx={r.coords.x} cy={r.coords.y} r="20" fill="url(#node-glow)" />
          <circle cx={r.coords.x} cy={r.coords.y} r="6" class="node-pulse-ring" style={`animation-delay: ${i * 0.5}s`} />
          <circle cx={r.coords.x} cy={r.coords.y} r="6" class="node-ring" />
          <circle cx={r.coords.x} cy={r.coords.y} r="3" class="node-core" filter="url(#glow)" />
        </g>
      ))}

      <rect class="scanline" x="30" y="241" width="784" height="1.5" />
    </svg>

    <!-- Tooltips -->
    {regions.map((r) => {
      const xPct = ((r.coords.x - 30.767) / 784.077) * 100;
      const yPct = ((r.coords.y - 241.591) / 458.627) * 100;
      return (
        <div class="node-overlay" style={`left: ${xPct}%; top: ${yPct}%`}>
          <div class="node-hitarea">
            <div class="node-tooltip">
              <div class="tt-header">
                <span class="tt-flag">{r.coords.flag}</span>
                <span class="tt-name">{r.coords.label}</span>
                <span class="tt-status">ONLINE</span>
              </div>
              <div class="tt-grid">
                <div class="tt-item">
                  <span class="tt-label">Status</span>
                  <span class="tt-value">{r.online === r.nodes ? 'Operational' : 'Degraded'}</span>
                </div>
                <div class="tt-item">
                  <span class="tt-label">Latency</span>
                  <span class="tt-value">{r.coords.latency}</span>
                </div>
                <div class="tt-item">
                  <span class="tt-label">Cache Hit</span>
                  <span class="tt-value">{r.coords.cached}</span>
                </div>
                <div class="tt-item">
                  <span class="tt-label">Uptime</span>
                  <span class="tt-value">99.9%</span>
                </div>
              </div>
              <div class="tt-bar"><div class="tt-bar-fill" style={`width: ${r.coords.cached}`}></div></div>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>

<style>
  .map-section { margin-bottom: 48px; }
  .map-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
  .map-header h2 { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.01em; }
  .map-stats { display: flex; align-items: center; gap: 20px; }
  .map-stat { display: flex; align-items: center; gap: 6px; }
  .stat-val { font-family: var(--mono); font-size: 0.85rem; font-weight: 700; color: #2ecc71; }
  .stat-label { font-size: 0.72rem; color: var(--text-dim); }
  .pulse { width: 7px; height: 7px; background: #2ecc71; border-radius: 50%; box-shadow: 0 0 8px rgba(46,204,113,0.6); animation: pulse-glow 2s ease-in-out infinite; }

  .map-container { overflow: hidden; background: transparent; position: relative; margin: 0 -32px; }
  .map-svg { display: block; width: 100%; height: auto; min-height: 250px; }
  @media (max-width: 768px) { .map-container { margin: 0 -16px; border-radius: 8px; } .map-header h2 { font-size: 1rem; } .map-stats { gap: 12px; } .stat-val { font-size: 0.75rem; } .stat-label { font-size: 0.65rem; } }
  @media (max-width: 480px) { .map-stats { display: none; } }

  .map-svg :global(.world-paths path) { fill: rgba(88,166,255,0.03); stroke: rgba(88,166,255,0.35); stroke-width: 0.4; }

  /* Mesh lines — subtle network backbone */
  .mesh-line { stroke: rgba(88,166,255,0.05); stroke-width: 0.3; }

  /* Nodes */
  .node-ring { fill: none; stroke: rgba(88,166,255,0.4); stroke-width: 0.6; }
  .node-core { fill: #58a6ff; }
  .node-pulse-ring { fill: none; stroke: rgba(88,166,255,0.25); stroke-width: 0.4; animation: svg-ripple 3s ease-out infinite; }
  .node-flash { fill: rgba(46,204,113,0.3); }

  /* Request trail */
  .request-trail { stroke: rgba(46,204,113,0.2); stroke-width: 0.5; stroke-dasharray: 2 2; }
  /* Propagation trail flash */
  .prop-trail { stroke: rgba(0,212,255,0.15); stroke-width: 0.8; }

  /* Query packets — green incoming user requests */
  .query-packet { fill: #2ecc71; filter: url(#glow); }
  /* Propagation — cyan spreading through mesh */
  .prop-packet { fill: #00d4ff; filter: url(#glow); }
  /* Response — soft white returning */
  .resp-packet { fill: rgba(255,255,255,0.6); }
  .resp-packet-user { fill: #2ecc71; filter: url(#glow); }

  .scanline { fill: rgba(88,166,255,0.03); animation: scan 6s linear infinite; }

  /* Tooltips */
  .node-overlay { position: absolute; transform: translate(-50%, -50%); z-index: 10; }
  .node-hitarea { width: 36px; height: 36px; cursor: pointer; position: relative; }
  .node-tooltip { position: absolute; top: 40px; left: 50%; transform: translateX(-50%) scale(0.9); background: rgba(13,17,23,0.95); border: 1px solid rgba(88,166,255,0.25); border-radius: 10px; padding: 14px 16px; width: 190px; opacity: 0; pointer-events: none; transition: all 0.2s ease; backdrop-filter: blur(12px); box-shadow: 0 8px 32px rgba(0,0,0,0.5), 0 0 20px rgba(88,166,255,0.08); z-index: 20; }
  .node-hitarea:hover .node-tooltip, .node-hitarea:active .node-tooltip { opacity: 1; transform: translateX(-50%) scale(1); pointer-events: auto; }
  @media (max-width: 768px) { .node-hitarea { width: 44px; height: 44px; } .node-tooltip { width: 170px; padding: 10px 12px; } .tt-header { margin-bottom: 8px; padding-bottom: 8px; } .tt-grid { gap: 6px; } .tt-name { font-size: 0.75rem; } .tt-value { font-size: 0.75rem; } }

  .tt-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid rgba(88,166,255,0.1); }
  .tt-flag { font-size: 0.65rem; font-weight: 700; color: var(--text-muted); background: rgba(88,166,255,0.08); padding: 2px 6px; border-radius: 3px; font-family: var(--mono); }
  .tt-name { font-size: 0.82rem; font-weight: 600; color: var(--text); flex: 1; }
  .tt-status { font-size: 0.6rem; font-weight: 700; color: #238636; letter-spacing: 0.05em; }
  .tt-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 10px; }
  .tt-item { display: flex; flex-direction: column; }
  .tt-label { font-size: 0.6rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .tt-value { font-size: 0.82rem; font-weight: 600; color: var(--accent); font-family: var(--mono); }
  .tt-bar { height: 3px; background: rgba(88,166,255,0.1); border-radius: 2px; overflow: hidden; }
  .tt-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), #79c0ff); border-radius: 2px; }

  @media (max-width: 768px) {
    .map-svg :global(.world-paths path) { stroke-width: 0.8; stroke: rgba(88,166,255,0.25); }
    .node-ring { stroke-width: 1.2; }
    .node-core { r: 4; }
    .mesh-line { stroke-width: 0.6; }
  }
  @media (max-width: 480px) {
    .map-section { margin-bottom: 32px; }
    .map-container { margin: 0 -12px; }
    .map-svg :global(.world-paths path) { stroke-width: 1.2; stroke: rgba(88,166,255,0.3); }
    .node-ring { stroke-width: 1.5; }
    .node-core { r: 5; }
    .mesh-line { stroke-width: 0.8; }
    .node-overlay { display: none; }
  }

  @keyframes pulse-glow { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  @keyframes svg-ripple { 0% { r: 6; opacity: 0.4; } 100% { r: 18; opacity: 0; } }
  @keyframes scan { 0% { y: 241; } 100% { y: 700; } }
</style>
