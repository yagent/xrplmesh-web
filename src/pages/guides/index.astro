---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const guides = [
  { title: 'XRPL API Guide', desc: 'WebSocket and JSON-RPC methods, account queries, transactions, NFTs, DEX, and AMM.', href: '/guides/xrpl-api', tags: ['API', 'WebSocket', 'RPC'], time: '15 min' },
  { title: 'Best XRPL Explorers', desc: 'Compare the top XRP Ledger block explorers. XRPSCAN, Bithomp, xrpl.to, and more.', href: '/guides/best-xrpl-explorers', tags: ['Tools', 'Explorer'], time: '8 min' },
  { title: 'Best XRP Wallets', desc: 'Compare Xaman, Crossmark, GemWallet, Ledger, and Trust Wallet for the XRPL.', href: '/guides/best-xrpl-wallets', tags: ['Wallets', 'Security'], time: '10 min' },
  { title: 'XRPL Trust Lines Explained', desc: 'How tokens work on the XRP Ledger. Creating trust lines, issuer controls, reserves, and API queries.', href: '/guides/xrpl-trust-lines', tags: ['Tokens', 'Trust Lines'], time: '10 min' },
  { title: 'XRPL AMM Guide', desc: 'Automated Market Maker pools on the XRP Ledger. Providing liquidity, LP tokens, fees, and API queries.', href: '/guides/xrpl-amm', tags: ['AMM', 'DeFi'], time: '10 min' },
];
---
<Base title="XRPL Guides — Developer Tutorials for XRP Ledger | XRPL Stream" description="Learn how to build on the XRP Ledger. Guides covering API integration, NFTs, tokens, DEX trading, full history nodes, and more.">
<Header />
<main class="guides-page">
  <div class="guides-container">
    <h1>Guides</h1>
    <p class="guides-intro">Learn how to build on the XRP Ledger. From your first API call to advanced DEX integrations.</p>

    <div class="guides-grid">
      {guides.map(g => (
        <a href={g.soon ? '#' : g.href} class={`guide-card${g.soon ? ' soon' : ''}`}>
          <div class="gc-tags">
            {g.tags.map(t => <span class="gc-tag">{t}</span>)}
            {g.soon && <span class="gc-tag gc-soon">Coming Soon</span>}
          </div>
          <h2>{g.title}</h2>
          <p>{g.desc}</p>
          <span class="gc-time">{g.time} read</span>
        </a>
      ))}
    </div>
  </div>
</main>
<Footer />
</Base>

<style>
  .guides-page { padding: 60px 0 80px; }
  .guides-container { max-width: 1400px; margin: 0 auto; padding: 0 40px; }
  h1 { font-size: 2.2rem; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 8px; }
  .guides-intro { font-size: 1.05rem; color: var(--text-muted); margin-bottom: 40px; }
  .guides-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .guide-card { display: block; padding: 24px; background: var(--surface); border: 1px solid var(--border); border-radius: 12px; transition: border-color 0.2s, transform 0.2s; }
  .guide-card:hover { border-color: var(--accent); transform: translateY(-2px); text-decoration: none; }
  .guide-card.soon { opacity: 0.5; pointer-events: none; }
  .gc-tags { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
  .gc-tag { font-size: 0.6rem; padding: 2px 8px; border-radius: 20px; background: rgba(77,158,255,0.08); color: var(--accent); font-weight: 600; letter-spacing: 0.02em; }
  .gc-soon { background: rgba(251,191,36,0.1); color: #fbbf24; }
  .guide-card h2 { font-size: 1.1rem; font-weight: 700; margin-bottom: 8px; color: var(--text); }
  .guide-card p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; margin-bottom: 12px; }
  .gc-time { font-size: 0.7rem; color: var(--text-dim); }
  @media (max-width: 600px) { .guides-grid { grid-template-columns: 1fr; } h1 { font-size: 1.6rem; } }
</style>
