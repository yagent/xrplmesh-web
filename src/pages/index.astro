    <script is:inline>
    // --- XRPL Command Flow ---
    (function() {
      const c = document.getElementById('cmd-flow');
      if (!c) return;
      const ctx = c.getContext('2d');
      let w, h;

      // Real XRPL rippled commands and data fragments
      const commands = [
        'account_info', 'account_lines', 'account_tx', 'account_offers',
        'account_currencies', 'account_channels', 'account_objects',
        'tx', 'submit', 'subscribe', 'ledger', 'ledger_closed',
        'ledger_current', 'ledger_data', 'ledger_entry',
        'server_info', 'server_state', 'fee', 'manifest',
        'book_offers', 'book_changes', 'path_find', 'ripple_path_find',
        'gateway_balances', 'channel_authorize', 'channel_verify',
        'nft_info', 'nft_buy_offers', 'nft_sell_offers', 'nfts_by_issuer',
        'deposit_authorized', 'noripple_check', 'random',
      ];

      // Data fragments that flash by -realistic XRPL payloads
      const fragments = [
        '"validated":true', '"ledger_index":103200841',
        '"type":"Payment"', '"status":"success"',
        '"fee":"12"', '"sequence":84291053',
        '"result":"tesSUCCESS"', '"type":"OfferCreate"',
        '"XRP":"1000000"', '"hash":"A3F1..."',
        '"owner_count":7', '"balance":"42891.204"',
        '"flags":0', '"limit":"100000000"',
        '"quality":"0.00000291"', '"taker_pays":{}',
        '"close_time":783241920', '"txn_count":47',
        '"reserve_base":10', '"load_factor":1',
        '"account":"r..."', '"destination":"r..."',
        '"delivered_amount":"500"', '"ledger_hash":"E7B2..."',
      ];

      const allText = [...commands, ...fragments];

      // Columns of flowing text
      let columns = [];
      const colWidth = 160;

      function makeItem(col, startY) {
        const isCmd = Math.random() > 0.4;
        const text = isCmd
          ? commands[Math.floor(Math.random() * commands.length)]
          : fragments[Math.floor(Math.random() * fragments.length)];
        return {
          text,
          isCmd,
          x: col * colWidth + (Math.random() * 60 - 30),
          y: startY !== undefined ? startY : -(Math.random() * h),
          speed: 0.3 + Math.random() * 0.7,
          alpha: 0,
          maxAlpha: isCmd ? 0.25 + Math.random() * 0.15 : 0.12 + Math.random() * 0.10,
          size: isCmd ? 13 : 11,
        };
      }

      function init() {
        w = c.width = c.parentElement.offsetWidth;
        h = c.height = c.parentElement.offsetHeight * 2;
        const numCols = Math.ceil(w / colWidth) + 1;
        columns = [];
        for (let col = 0; col < numCols; col++) {
          const itemCount = 6 + Math.floor(Math.random() * 5);
          for (let i = 0; i < itemCount; i++) {
            const item = makeItem(col);
            item.y = Math.random() * h; // Spread on init
            item.alpha = item.maxAlpha * Math.random();
            columns.push(item);
          }
        }
      }

      function draw() {
        ctx.clearRect(0, 0, w, h);

        // Subtle grid underlay
        ctx.strokeStyle = 'rgba(88,166,255,0.025)';
        ctx.lineWidth = 0.5;
        for (let x = 0; x < w; x += 60) {
          ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, h); ctx.stroke();
        }

        for (let i = 0; i < columns.length; i++) {
          const item = columns[i];
          item.y += item.speed;

          // Fade in at top, fade out at bottom
          const fadeIn = Math.min(1, item.y / 100);
          const fadeOut = Math.max(0, 1 - item.y / (h * 0.85));
          item.alpha = item.maxAlpha * fadeIn * fadeOut;

          if (item.alpha > 0.01) {
            const hue = item.isCmd ? 210 : 200;
            const sat = item.isCmd ? 80 : 40;
            const light = item.isCmd ? 65 : 55;
            ctx.font = (item.isCmd ? '600 ' : '400 ') + item.size + 'px "SF Mono", Consolas, "Liberation Mono", monospace';
            ctx.fillStyle = `hsla(${hue},${sat}%,${light}%,${item.alpha.toFixed(3)})`;
            ctx.fillText(item.text, item.x, item.y);
          }

          // Recycle when off-screen
          if (item.y > h) {
            const col = Math.floor((item.x + 30) / colWidth);
            Object.assign(item, makeItem(col, -(10 + Math.random() * 80)));
          }
        }

        requestAnimationFrame(draw);
      }

      requestAnimationFrame(() => { init(); draw(); });
      window.addEventListener('resize', init);
    })();

    // --- Live data ticker ---
    (function() {
      const ledgerEl = document.getElementById('hero-ledger');
      if (!ledgerEl) return;
      async function tick() {
        try {
          const r = await fetch('/api/stats');
          if (!r.ok) return;
          const d = await r.json();
          if (d.latest_ledger) ledgerEl.textContent = d.latest_ledger.toLocaleString();
        } catch {}
      }
      setInterval(tick, 4000);
    })();
    </script>

    <Footer />
  </div>
</Base>

