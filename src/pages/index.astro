---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ApiDocs from '../components/ApiDocs.astro';
import { Zap, Globe, ShieldCheck, RefreshCw, Cable, KeyRound, Banknote, TrendingUp, Image, BarChart3, ArrowRight, Wallet, Building2 } from 'lucide-astro';
import { getSessionFromCookie } from '../lib/auth';

const session = getSessionFromCookie(Astro.request);
const ADMIN_TOKEN = import.meta.env.ADMIN_TOKEN || '';

let userPlan = '';
if (session) {
  try {
    const kr = await fetch(`${import.meta.env.API_URL || 'http://127.0.0.1:9000'}/admin/keys`, {
      headers: { 'X-Proxy-Token': ADMIN_TOKEN },
      signal: AbortSignal.timeout(3000),
    });
    if (kr.ok) {
      const keys = await kr.json();
      const owned = keys.find((k: any) => k.owner === session.email && k.active);
      if (owned) userPlan = owned.plan;
    }
  } catch {}
}

const API_URL = import.meta.env.API_URL || 'https://s1.xrpl.stream';
// SSR: fetch from local node (same server), fallback to public API
const SSR_URL = import.meta.env.SSR_API_URL || 'http://127.0.0.1:9000';
let network = {
  nodes_total: 0, nodes_online: 0, latest_ledger: 0,
  total_requests_served: 0, regions: {},
};

try {
  const res = await fetch(`${SSR_URL}/network`, { signal: AbortSignal.timeout(3000) });
  if (res.ok) {
    const d = await res.json();
    if (d.nodes_total && d.latest_ledger) network = d;
  }
} catch {}
if (!network.nodes_total) {
  try {
    const res = await fetch(`${API_URL}/network`, { signal: AbortSignal.timeout(5000) });
    if (res.ok) {
      const d = await res.json();
      if (d.nodes_total && d.latest_ledger) network = d;
    }
  } catch {}
}

---

