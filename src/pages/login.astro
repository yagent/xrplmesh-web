---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getSessionFromCookie } from '../lib/auth';

const session = getSessionFromCookie(Astro.request);
if (session) return Astro.redirect('/dashboard');
---

<Base title="Sign In - XRPL Stream" description="Sign in to XRPL Stream to get your API endpoint.">
  <Header />

  <div class="login-page">
    <div class="login-card">
      <h1>Sign in to XRPL Stream</h1>
      <p>Get your API endpoint in seconds.</p>

      <!-- Xaman QR -->
      <div id="xaman-section">
        <button class="login-btn xaman" id="xaman-btn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 7h.01M7 17h.01M17 7h.01M17 17h.01"/><rect x="8" y="8" width="8" height="8" rx="1"/></svg>
          Sign in with Xaman
        </button>
        <div id="xaman-qr" class="xaman-qr hidden">
          <img id="xaman-qr-img" alt="Scan with Xaman" />
          <p class="xaman-hint">Scan with your Xaman wallet</p>
          <div id="xaman-status" class="xaman-status">Waiting for signature...</div>
        </div>
      </div>

      <div class="login-divider"><span>or</span></div>

      <div class="login-buttons">
        <a href="/api/auth/login" class="login-btn google">
          <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          Continue with Google
        </a>
        <a href="/api/auth/github/login" class="login-btn github">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Continue with GitHub
        </a>
      </div>

      <p class="login-note">By signing in, you agree to our terms of service.</p>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .login-page { display: flex; align-items: center; justify-content: center; min-height: calc(100vh - 160px); padding: 40px 16px; }
  .login-card { text-align: center; max-width: 380px; width: 100%; }
  .login-card h1 { font-size: 1.5rem; font-weight: 700; margin-bottom: 8px; }
  .login-card > p { color: var(--text-muted); font-size: 0.92rem; margin-bottom: 32px; }

  .login-buttons { display: flex; flex-direction: column; gap: 12px; margin-bottom: 24px; }
  .login-btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    padding: 12px 20px; border-radius: 8px; font-weight: 600; font-size: 0.9rem;
    transition: all 0.2s; cursor: pointer; text-decoration: none;
  }
  .login-btn:hover { text-decoration: none; }

  .login-btn.google {
    background: #fff; color: #333; border: 1px solid #ddd;
  }
  .login-btn.google:hover { background: #f5f5f5; border-color: #ccc; }

  .login-btn.github {
    background: #24292f; color: #fff; border: 1px solid #444;
  }
  .login-btn.github:hover { background: #2f363d; }

  .login-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; }
  .login-divider::before, .login-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .login-divider span { font-size: 0.75rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.08em; }

  .login-btn.xaman { background: #1a1d24; color: #fff; border: 1px solid #333; width: 100%; }
  .login-btn.xaman:hover { background: #24282f; border-color: #58a6ff; }

  .xaman-qr { margin-top: 16px; display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .xaman-qr.hidden { display: none; }
  .xaman-qr img { width: 200px; height: 200px; border-radius: 12px; background: #fff; }
  .xaman-hint { font-size: 0.8rem; color: var(--text-muted); }
  .xaman-status { font-size: 0.72rem; color: var(--accent); font-family: var(--mono); }

  .login-note { font-size: 0.72rem; color: var(--text-dim); }
</style>

<script is:inline>
  document.getElementById('xaman-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('xaman-btn');
    const qrDiv = document.getElementById('xaman-qr');
    const qrImg = document.getElementById('xaman-qr-img');
    const status = document.getElementById('xaman-status');
    btn.disabled = true;
    btn.textContent = 'Loading...';

    try {
      const resp = await fetch('/api/auth/xaman/login');
      if (!resp.ok) throw new Error('Failed');
      const data = await resp.json();

      qrImg.src = data.qr;
      qrDiv.classList.remove('hidden');
      btn.style.display = 'none';
      status.textContent = 'Waiting for signature...';

      // Listen for signature via WebSocket
      const ws = new WebSocket(data.ws);
      ws.onmessage = async (e) => {
        const msg = JSON.parse(e.data);
        if (msg.signed === true) {
          status.textContent = 'Signed! Verifying...';
          ws.close();
          const verify = await fetch('/api/auth/xaman/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ uuid: data.uuid }),
          });
          const result = await verify.json();
          if (result.ok) {
            document.cookie = `session=${result.sessionId}; Path=/; Max-Age=${7*24*60*60}; SameSite=Lax`;
            window.location.href = '/dashboard';
          } else {
            status.textContent = 'Verification failed. Try again.';
          }
        } else if (msg.signed === false) {
          status.textContent = 'Rejected. Try again.';
          ws.close();
          setTimeout(() => {
            qrDiv.classList.add('hidden');
            btn.style.display = 'flex';
            btn.disabled = false;
            btn.textContent = 'Sign in with Xaman';
          }, 2000);
        }
      };
    } catch (e) {
      btn.disabled = false;
      btn.textContent = 'Sign in with Xaman';
      alert('Failed to connect to Xaman');
    }
  });
</script>
