---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Check, ArrowRight, Zap, Shield, CreditCard } from 'lucide-astro';
import { getSessionFromCookie } from '../lib/auth';

const session = getSessionFromCookie(Astro.request);
const ADMIN_TOKEN = import.meta.env.ADMIN_TOKEN || '';

let userPlan = '';
if (session) {
  try {
    const kr = await fetch(`${import.meta.env.API_URL || 'http://127.0.0.1:9000'}/admin/keys`, {
      headers: { 'X-Proxy-Token': ADMIN_TOKEN },
      signal: AbortSignal.timeout(3000),
    });
    if (kr.ok) {
      const keys = await kr.json();
      const owned = keys.find((k: any) => k.owner === session.email && k.active);
      if (owned) userPlan = owned.plan;
    }
  } catch {}
}

const planTier: Record<string, number> = { free: 0, builder: 1, pro: 2, scale: 3, enterprise: 4 };
const currentTier = planTier[userPlan] ?? -1;

const plans = [
  { name: 'Free', price: '$0', period: '/forever', plan: 'free', limit: '15 req/s', credits: '10M', features: ['Full ledger history', 'WebSocket & HTTP', 'Mainnet, testnet, devnet', 'Community support'], cta: 'Start Building', highlight: false },
  { name: 'Builder', price: '$39', period: '/month', plan: 'builder', limit: '50 req/s', credits: '100M', features: ['Everything in Free', 'Priority routing', 'Usage dashboard', 'Chat support'], cta: 'Subscribe', highlight: false },
  { name: 'Pro', price: '$149', period: '/month', plan: 'pro', limit: '125 req/s', credits: '500M', features: ['Everything in Builder', 'Higher throughput', 'Dedicated support', 'Advanced analytics'], cta: 'Subscribe', highlight: true },
  { name: 'Scale', price: '$299', period: '/month', plan: 'scale', limit: '250 req/s', credits: '2B', features: ['Everything in Pro', 'Maximum throughput', 'Custom SLA', 'Priority support'], cta: 'Subscribe', highlight: false },
  { name: 'Enterprise', price: '$699', period: '/month', plan: 'enterprise', limit: '500 req/s', credits: '5B', features: ['Everything in Scale', 'Highest throughput', 'Dedicated infrastructure', 'Enterprise SLA'], cta: 'Subscribe', highlight: false },
];

function getCta(plan: string) {
  const tier = planTier[plan] ?? 0;
  if (currentTier >= 4) return 'Enterprise';
  if (plan === userPlan) return 'Current Plan';
  if (tier < currentTier) return 'Current: ' + userPlan.charAt(0).toUpperCase() + userPlan.slice(1);
  if (plan === 'free') return userPlan ? 'Current: ' + userPlan.charAt(0).toUpperCase() + userPlan.slice(1) : 'Start Building';
  return 'Subscribe';
}

function isDisabled(plan: string) {
  const tier = planTier[plan] ?? 0;
  return currentTier >= 4 || plan === userPlan || tier <= currentTier;
}
---

<Base title="Pricing - XRPL Stream" description="Simple, transparent pricing for XRP Ledger infrastructure. Full history on every plan. Free to start, scale when you're ready." schema={{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is XRPL Stream?", "acceptedAnswer": { "@type": "Answer", "text": "XRPL Stream is a globally distributed XRP Ledger API providing full history access to every transaction since genesis. It supports WebSocket and JSON-RPC across mainnet, testnet, and devnet." } },
    { "@type": "Question", "name": "Is there a free plan?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. The free tier includes 15 requests per second and 10 million credits per month. No credit card required." } },
    { "@type": "Question", "name": "What counts as a credit?", "acceptedAnswer": { "@type": "Answer", "text": "Every API request costs 40 credits regardless of method or response size." } },
    { "@type": "Question", "name": "Do I need to change my code?", "acceptedAnswer": { "@type": "Answer", "text": "No. XRPL Stream is a drop-in replacement for any XRPL endpoint. Swap your URL and everything works with xrpl.js, xrpl-py, xrpl4j, ripple-lib, and any other client library." } },
    { "@type": "Question", "name": "Does XRPL Stream support full ledger history?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Every plan includes access to the complete XRP Ledger history from genesis ledger 32570 through the latest validated close." } },
    { "@type": "Question", "name": "Which networks are supported?", "acceptedAnswer": { "@type": "Answer", "text": "Mainnet, testnet, and devnet are all available from a single endpoint." } },
    { "@type": "Question", "name": "Can I cancel my subscription?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. There are no contracts or commitments. You can switch plans or cancel at any time." } }
  ]
}}>
  <Header />

  <div class="container">
    <div class="pricing-hero">
      <h1>Simple pricing for teams of any scale</h1>
      <p class="pricing-lead">Full ledger history on every plan. No archive add-ons, no surprise fees.</p>
    </div>

    <div class="pricing-grid">
      {plans.map(p => (
        <div class={`plan ${p.highlight && p.plan !== userPlan ? 'plan-highlight' : ''} ${p.plan === userPlan ? 'plan-current' : ''}`}>
          {p.plan === userPlan && <div class="plan-badge current-badge">Your Plan</div>}
          {p.highlight && p.plan !== userPlan && <div class="plan-badge">Recommended</div>}
          <div class="plan-header">
            <div class="plan-name">{p.name}</div>
            <div class="plan-price">
              <span class="price">{p.price}</span>
              <span class="period">{p.period}</span>
            </div>
          </div>
          <div class="plan-metrics">
            <div class="metric">
              <span class="metric-value">{p.limit}</span>
              <span class="metric-label">Rate limit</span>
            </div>
            <div class="metric">
              <span class="metric-value">{p.credits}</span>
              <span class="metric-label">Credits/mo</span>
            </div>
          </div>
          <div class="plan-divider"></div>
          <ul class="plan-features">
            {p.features.map(f => (
              <li><Check size={14} /><span>{f}</span></li>
            ))}
          </ul>
          <button
            class={`plan-cta ${p.plan === userPlan ? 'plan-cta-current' : ''}`}
            data-plan={p.plan}
            disabled={isDisabled(p.plan)}
            onclick={isDisabled(p.plan) ? undefined : p.plan === 'free'
              ? "window.location.href='/login'"
              : `handleCheckout('${p.plan}')`
            }
          >
            {getCta(p.plan)}
          </button>
          {p.plan !== 'free' && !isDisabled(p.plan) && (
            <button class="plan-xrp" onclick={`handleXrpCheckout('${p.plan}')`}>
              Pay with XRP
            </button>
          )}
        </div>
      ))}
    </div>

    <!-- Compare table -->
    <section class="compare">
      <h2>Compare plans</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th></th>
              <th>Free</th>
              <th>Builder</th>
              <th class="th-highlight">Pro</th>
              <th>Scale</th>
              <th>Enterprise</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="row-label">Price / month</td><td>$0</td><td>$39</td><td>$149</td><td>$299</td><td>$699</td></tr>
            <tr><td class="row-label">Credits / month</td><td>10M</td><td>100M</td><td>500M</td><td>2B</td><td>5B</td></tr>
            <tr><td class="row-label">Requests / second</td><td>15</td><td>50</td><td>125</td><td>250</td><td>500</td></tr>
            <tr><td class="row-label">Full ledger history</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">WebSocket & HTTP</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Testnet & Devnet</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Priority routing</td><td class="dim">-</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Usage dashboard</td><td class="dim">-</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Dedicated support</td><td class="dim">-</td><td class="dim">-</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Custom SLA</td><td class="dim">-</td><td class="dim">-</td><td class="dim">-</td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Dedicated infrastructure</td><td class="dim">-</td><td class="dim">-</td><td class="dim">-</td><td class="dim">-</td><td><Check size={14} /></td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Trust section -->
    <section class="trust">
      <div class="trust-grid">
        <div class="trust-card">
          <Zap size={20} />
          <h3>Try before you commit</h3>
          <p>Start free with no credit card. When your project needs more, paid plans scale with you.</p>
        </div>
        <div class="trust-card">
          <Shield size={20} />
          <h3>No surprise overages</h3>
          <p>Requests beyond your plan are rate limited, not billed. You always know what you will pay.</p>
        </div>
        <div class="trust-card">
          <CreditCard size={20} />
          <h3>Pay how you want</h3>
          <p>Pay with XRP, Stripe, or Cash App. No contracts, no commitments. Switch plans or cancel anytime.</p>
        </div>
      </div>
    </section>

    <!-- Enterprise callout -->
    <section class="enterprise">
      <div class="ent-inner">
        <div>
          <h2>Need more?</h2>
          <p>Custom rate limits, dedicated infrastructure, and SLAs for teams at enterprise scale.</p>
        </div>
        <a href="mailto:hello@xrpl.to" class="btn btn-ghost">Contact us <ArrowRight size={14} /></a>
      </div>
    </section>
    <!-- Comparison -->
    <section class="vs">
      <h2>XRPL Stream vs. other providers</h2>
      <p class="vs-sub">Built natively for the XRP Ledger. Not a multi-chain afterthought.</p>
      <div class="table-wrap">
        <table class="vs-table">
          <thead>
            <tr>
              <th></th>
              <th class="th-highlight">XRPL Stream</th>
              <th>QuickNode</th>
              <th>NOWNodes</th>
            </tr>
          </thead>
          <tbody>
            <tr><td class="row-label">XRP Ledger native</td><td><Check size={14} /></td><td class="dim">Multi-chain</td><td class="dim">Multi-chain</td></tr>
            <tr><td class="row-label">Full ledger history</td><td><Check size={14} /></td><td class="dim">Add-on</td><td class="dim">Limited</td></tr>
            <tr><td class="row-label">Free tier</td><td><Check size={14} /></td><td><Check size={14} /></td><td class="dim">-</td></tr>
            <tr><td class="row-label">WebSocket subscriptions</td><td><Check size={14} /></td><td><Check size={14} /></td><td class="dim">-</td></tr>
            <tr><td class="row-label">Testnet & Devnet</td><td><Check size={14} /></td><td><Check size={14} /></td><td class="dim">-</td></tr>
            <tr><td class="row-label">No API key for basic access</td><td><Check size={14} /></td><td class="dim">-</td><td class="dim">-</td></tr>
            <tr><td class="row-label">Drop-in xrpl.js compatible</td><td><Check size={14} /></td><td><Check size={14} /></td><td><Check size={14} /></td></tr>
            <tr><td class="row-label">Starting price</td><td class="accent-val">$0</td><td>$49/mo</td><td>$20/mo</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq">
      <h2>Frequently asked questions</h2>
      <div class="faq-grid">
        <details class="faq-item">
          <summary>What is XRPL Stream?</summary>
          <p>XRPL Stream is a globally distributed XRP Ledger API providing full history access to every transaction since genesis. It supports WebSocket and JSON-RPC across mainnet, testnet, and devnet.</p>
        </details>
        <details class="faq-item">
          <summary>Is there a free plan?</summary>
          <p>Yes. The free tier includes 15 requests per second and 10 million credits per month. No credit card required. Sign in with Google and get your endpoint instantly.</p>
        </details>
        <details class="faq-item">
          <summary>What counts as a credit?</summary>
          <p>Every API request costs 40 credits regardless of method or response size. This keeps billing simple and predictable.</p>
        </details>
        <details class="faq-item">
          <summary>What happens if I exceed my rate limit?</summary>
          <p>Requests beyond your plan's rate limit are returned with a 429 status code. You are never billed for overages. Upgrade your plan anytime for higher throughput.</p>
        </details>
        <details class="faq-item">
          <summary>Do I need to change my code?</summary>
          <p>No. XRPL Stream is a drop-in replacement for any XRPL endpoint. Swap your URL and everything works with xrpl.js, xrpl-py, xrpl4j, ripple-lib, and any other client library.</p>
        </details>
        <details class="faq-item">
          <summary>Does XRPL Stream support full ledger history?</summary>
          <p>Yes. Every plan includes access to the complete XRP Ledger history from genesis ledger 32570 through the latest validated close. No archive add-ons required.</p>
        </details>
        <details class="faq-item">
          <summary>Which networks are supported?</summary>
          <p>Mainnet, testnet, and devnet are all available from a single endpoint. Prefix your request path with /testnet or /devnet to switch networks.</p>
        </details>
        <details class="faq-item">
          <summary>Can I cancel my subscription?</summary>
          <p>Yes. There are no contracts or commitments. You can switch plans or cancel at any time from your dashboard.</p>
        </details>
      </div>
    </section>
  </div>

  <!-- XRP Payment Modal -->
  <div id="xrp-modal" class="xrp-modal hidden">
    <div class="xrp-modal-card">
      <button class="xrp-close" onclick="closeXrpModal()">&times;</button>
      <h3>Pay with XRP</h3>
      <p class="xrp-plan-info">Plan: <strong id="xrp-plan-name"></strong> &middot; <strong id="xrp-amount"></strong> XRP</p>
      <div class="xrp-details">
        <div class="xrp-field">
          <span class="xrp-label">Send to</span>
          <code id="xrp-address" class="xrp-val"></code>
        </div>
        <div class="xrp-field">
          <span class="xrp-label">Destination Tag</span>
          <code id="xrp-tag" class="xrp-val xrp-tag-highlight"></code>
        </div>
        <div class="xrp-field">
          <span class="xrp-label">Amount</span>
          <code id="xrp-amount-drops" class="xrp-val"></code>
        </div>
      </div>
      <p class="xrp-warning">Include the destination tag or your payment cannot be verified.</p>
      <div class="xrp-actions">
        <button id="xrp-verify-btn" class="btn btn-primary" onclick="verifyXrpPayment()">I've sent the payment</button>
      </div>
      <p id="xrp-status" class="xrp-status"></p>
      <p class="xrp-expires">Payment window expires in <span id="xrp-timer">15:00</span></p>
    </div>
  </div>

  <script is:inline>
    async function handleCheckout(plan) {
      try {
        const resp = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });
        const data = await resp.json();
        if (resp.status === 401) {
          window.location.href = data.redirect || '/login';
          return;
        }
        if (data.url) window.location.href = data.url;
        else alert('Error: ' + (data.error || 'Unknown error'));
      } catch (e) {
        alert('Failed to create checkout session');
      }
    }

    var _xrpTag = 0;
    var _xrpTimer = null;

    async function handleXrpCheckout(plan) {
      try {
        const resp = await fetch('/api/xrp-checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ plan }),
        });
        const data = await resp.json();
        if (resp.status === 401) {
          window.location.href = data.redirect || '/login';
          return;
        }
        if (data.error) { alert(data.error); return; }

        _xrpTag = data.destinationTag;
        document.getElementById('xrp-plan-name').textContent = plan.charAt(0).toUpperCase() + plan.slice(1);
        document.getElementById('xrp-amount').textContent = data.amount;
        document.getElementById('xrp-address').textContent = data.address;
        document.getElementById('xrp-tag').textContent = data.destinationTag;
        document.getElementById('xrp-amount-drops').textContent = data.amount + ' XRP (' + data.amountDrops + ' drops)';
        document.getElementById('xrp-status').textContent = '';
        document.getElementById('xrp-modal').classList.remove('hidden');

        // Timer
        var secs = data.expiresIn || 900;
        clearInterval(_xrpTimer);
        _xrpTimer = setInterval(function() {
          secs--;
          if (secs <= 0) { clearInterval(_xrpTimer); closeXrpModal(); alert('Payment window expired'); return; }
          var m = Math.floor(secs/60), s = secs%60;
          document.getElementById('xrp-timer').textContent = m + ':' + (s<10?'0':'') + s;
        }, 1000);
      } catch (e) {
        alert('Failed to create XRP payment');
      }
    }

    async function verifyXrpPayment() {
      var btn = document.getElementById('xrp-verify-btn');
      var status = document.getElementById('xrp-status');
      btn.disabled = true;
      btn.textContent = 'Verifying...';
      status.textContent = 'Checking the ledger...';
      status.style.color = 'var(--accent)';

      try {
        var resp = await fetch('/api/xrp-verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ destinationTag: _xrpTag }),
        });
        var data = await resp.json();
        if (data.verified) {
          status.textContent = 'Payment verified! Redirecting...';
          status.style.color = '#3fb950';
          clearInterval(_xrpTimer);
          setTimeout(function() { window.location.href = '/dashboard'; }, 1500);
        } else {
          status.textContent = data.message || 'Payment not found yet. Try again in a moment.';
          status.style.color = '#d29922';
          btn.disabled = false;
          btn.textContent = "I've sent the payment";
        }
      } catch (e) {
        status.textContent = 'Verification failed. Try again.';
        status.style.color = '#f85149';
        btn.disabled = false;
        btn.textContent = "I've sent the payment";
      }
    }

    function closeXrpModal() {
      document.getElementById('xrp-modal').classList.add('hidden');
      clearInterval(_xrpTimer);
    }
  </script>

  <Footer />
</Base>

<style>
  .container { max-width: 1400px; margin: 0 auto; padding: 48px 40px 64px; }

  .pricing-hero { text-align: center; margin-bottom: 48px; }
  .pricing-hero h1 { font-size: 2.2rem; font-weight: 800; margin-bottom: 12px; letter-spacing: -0.02em; }
  .pricing-lead { color: var(--text-muted); font-size: 1.05rem; max-width: 500px; margin: 0 auto; }

  .pricing-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-bottom: 64px; }
  .plan { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 28px 24px; display: flex; flex-direction: column; position: relative; transition: border-color 0.2s, transform 0.2s; }
  .plan:hover { border-color: rgba(88,166,255,0.3); transform: translateY(-2px); }
  .plan-highlight { border-color: var(--accent); box-shadow: 0 0 30px rgba(88,166,255,0.08); }
  .plan-badge { position: absolute; top: -10px; left: 50%; transform: translateX(-50%); background: var(--accent); color: #fff; font-size: 0.65rem; font-weight: 700; padding: 3px 12px; border-radius: 10px; text-transform: uppercase; letter-spacing: 0.05em; }
  .plan-header { margin-bottom: 20px; }
  .plan-name { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.06em; }
  .plan-price { display: flex; align-items: baseline; gap: 2px; }
  .price { font-size: 2.2rem; font-weight: 800; color: var(--text); letter-spacing: -0.02em; }
  .period { font-size: 0.8rem; color: var(--text-dim); }
  .plan-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 16px; }
  .metric { background: rgba(88,166,255,0.04); border: 1px solid rgba(88,166,255,0.08); border-radius: 8px; padding: 10px; text-align: center; }
  .metric-value { display: block; font-size: 0.95rem; font-weight: 700; color: var(--accent); font-family: var(--mono); }
  .metric-label { display: block; font-size: 0.65rem; color: var(--text-dim); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.05em; }
  .plan-divider { height: 1px; background: var(--border); margin-bottom: 16px; }
  .plan-features { list-style: none; padding: 0; flex: 1; margin-bottom: 20px; }
  .plan-features li { display: flex; align-items: center; gap: 8px; padding: 5px 0; font-size: 0.83rem; color: var(--text-muted); }
  .plan-features li :global(svg) { color: var(--accent); flex-shrink: 0; }
  .plan-cta { width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--border); background: transparent; color: var(--text); font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; font-family: var(--font); }
  .plan-cta:hover { border-color: var(--accent); color: var(--accent); }
  .plan-highlight .plan-cta { background: var(--accent); color: #fff; border-color: var(--accent); }
  .plan-highlight .plan-cta:hover { background: #79c0ff; }
  .plan-current { border-color: #3fb950; box-shadow: 0 0 30px rgba(63,185,80,0.08); }
  .current-badge { background: #3fb950 !important; }
  .plan-cta-current { border-color: #3fb950; color: #3fb950; cursor: default; }
  .plan-cta:disabled { opacity: 0.4; cursor: not-allowed; }
  .plan-cta:disabled:hover { border-color: var(--border); color: var(--text); }
  .plan-xrp { width: 100%; padding: 8px; border-radius: 6px; border: 1px solid rgba(63,185,80,0.2); background: rgba(63,185,80,0.06); color: #3fb950; font-size: 0.78rem; font-weight: 600; cursor: pointer; transition: all 0.2s; font-family: var(--font); margin-top: 6px; }
  .plan-xrp:hover { border-color: #3fb950; background: rgba(63,185,80,0.12); }

  /* XRP Modal */
  .xrp-modal { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.8); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; padding: 20px; }
  .xrp-modal.hidden { display: none; }
  .xrp-modal-card { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 32px; max-width: 440px; width: 100%; position: relative; }
  .xrp-close { position: absolute; top: 12px; right: 16px; background: none; border: none; color: var(--text-muted); font-size: 1.4rem; cursor: pointer; }
  .xrp-modal-card h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
  .xrp-plan-info { color: var(--text-muted); font-size: 0.88rem; margin-bottom: 20px; }
  .xrp-details { display: flex; flex-direction: column; gap: 12px; margin-bottom: 16px; }
  .xrp-field { display: flex; flex-direction: column; gap: 4px; }
